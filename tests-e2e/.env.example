# AI Tester - konfiguracja
# Skopiuj do .env i uzupelnij

# URL aplikacji (default: test.krzewiny.net:8888)
KSEF_BASE_URL=http://test.krzewiny.net:8888

# Credentials testowe (UI login)
# UWAGA: to konto bedzie uzywane do testow GUI - powinno byc dedykowane
KSEF_TEST_USER=
KSEF_TEST_PASS=

# Bearer token do API tests (opcjonalne)
KSEF_API_TOKEN=

# Tryb headed (true = widoczna przegladarka, false = headless)
KSEF_HEADED=false

# Slow motion (ms) - spowalnia akcje, zeby widziec co sie dzieje
KSEF_SLOWMO=0

# Timeout dla akcji (ms)
KSEF_TIMEOUT=10000

# Czy testowac destructive (rate limit, password change) - default: false
KSEF_RUN_DESTRUCTIVE=false
