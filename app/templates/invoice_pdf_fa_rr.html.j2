<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
    @page {
        size: A4;
        margin: 12mm 12mm 18mm 12mm;

        @frame footer_frame {
            -pdf-frame-content: page-footer-content;
            left: 12mm;
            width: 186mm;
            bottom: 0mm;
            height: 12mm;
        }
    }

    {% if font_paths.regular %}
    @font-face {
        font-family: "{{ font_name }}";
        src: url("{{ font_paths.regular }}");
    }
    {% if font_paths.bold %}
    @font-face {
        font-family: "{{ font_name }}";
        font-weight: bold;
        src: url("{{ font_paths.bold }}");
    }
    {% endif %}
    {% endif %}
    body {
        font-family: "{{ font_name }}", "{{ font_name_bold }}", "DejaVuSans", "Arial", "Helvetica", sans-serif;
        font-size: 9pt;
        line-height: 1.3;
        color: #000000;
        margin: 0;
        padding: 0;
    }

    .ksef-branding {
        font-size: 8pt;
        font-weight: bold;
        color: #333333;
        margin-bottom: 3mm;
    }
    .ksef-e { color: red; }

    .invoice-title {
        font-size: 14pt;
        font-weight: bold;
        text-align: center;
        margin-bottom: 2mm;
    }
    .invoice-subtitle {
        font-size: 11pt;
        font-weight: bold;
        text-align: center;
        margin-bottom: 3mm;
    }

    /* Info grid */
    .info-table { width: 100%; margin-bottom: 4mm; border-collapse: collapse; }
    .info-table td { padding: 1pt 2pt; vertical-align: top; font-size: 8.5pt; }
    .info-label { font-weight: normal; color: #555555; width: 45mm; }
    .info-value { font-weight: bold; }

    /* Parties */
    .parties-table { width: 100%; border-collapse: collapse; margin-bottom: 4mm; }
    .party-cell {
        width: 50%;
        vertical-align: top;
        border: 0.5pt solid #999999;
        padding: 3mm;
    }
    .party-title { font-size: 7.5pt; font-weight: bold; color: #555555; text-transform: uppercase; letter-spacing: 0.5pt; margin-bottom: 2pt; }
    .party-name { font-size: 9pt; font-weight: bold; }
    .party-detail { font-size: 8pt; color: #333333; }

    /* RR specific section */
    .rr-section { margin-bottom: 4mm; }
    .rr-section-title {
        font-size: 8pt;
        font-weight: bold;
        color: #555555;
        text-transform: uppercase;
        letter-spacing: 0.5pt;
        border-bottom: 0.5pt solid #cccccc;
        padding-bottom: 1pt;
        margin-bottom: 2mm;
    }
    .rr-table { width: 100%; border-collapse: collapse; margin-bottom: 4mm; }
    .rr-table td { padding: 1pt 2pt; vertical-align: top; font-size: 8.5pt; }
    .rr-label { font-weight: normal; color: #555555; width: 65mm; }
    .rr-value { font-weight: bold; }

    /* Items table */
    .items-table { width: 100%; border-collapse: collapse; margin-bottom: 4mm; font-size: 8pt; }
    .items-table th {
        background-color: #e8e8e8;
        font-weight: bold;
        text-align: center;
        padding: 2pt 3pt;
        border: 0.5pt solid #999999;
    }
    .items-table td {
        padding: 2pt 3pt;
        border: 0.5pt solid #cccccc;
        vertical-align: top;
    }
    .items-table .col-no { width: 6mm; text-align: center; }
    .items-table .col-name { }
    .items-table .col-unit { width: 10mm; text-align: center; }
    .items-table .col-qty { width: 14mm; text-align: right; }
    .items-table .col-price { width: 22mm; text-align: right; }
    .items-table .col-net { width: 22mm; text-align: right; }
    .items-table .col-vat { width: 16mm; text-align: center; }

    /* Totals */
    .totals-table { width: 100%; border-collapse: collapse; margin-bottom: 4mm; }
    .totals-table td { padding: 2pt 3pt; font-size: 9pt; }
    .total-label { text-align: right; color: #333333; }
    .total-value { font-weight: bold; text-align: right; width: 45mm; }
    .total-grand { font-size: 11pt; font-weight: bold; border-top: 1pt solid #000000; }

    /* Declaration box */
    .declaration-box {
        border: 0.5pt solid #999999;
        padding: 3mm;
        margin-bottom: 4mm;
        font-size: 8pt;
    }
    .declaration-title { font-weight: bold; margin-bottom: 2pt; }
    .declaration-text { line-height: 1.5; }

    /* Page footer */
    .page-footer {
        font-size: 6pt;
        color: #888888;
        text-align: center;
    }
</style>
</head>
<body>

<!-- Page footer (repeated on every page via PDF frame) -->
<div id="page-footer-content">
    <p class="page-footer">Wygenerowane przez KSeF Monitor | {{ generation_stamp }}</p>
</div>

<!-- KSeF branding -->
<p class="ksef-branding">
    Krajowy System <span class="ksef-e">e</span>-Faktur
    (KS<span class="ksef-e">e</span>F){% if ksef_number %}: {{ ksef_number }}{% endif %}
</p>

<!-- Title -->
<p class="invoice-title">FAKTURA VAT RR</p>
{% if header.kod_formularza %}
<p class="invoice-subtitle">{{ header.kod_formularza }}{% if header.wariant %} ({{ header.wariant }}){% endif %}</p>
{% endif %}

<!-- Invoice header info -->
<table class="info-table">
    {% if header.p2 %}
    <tr>
        <td class="info-label">Numer faktury:</td>
        <td class="info-value">{{ header.p2 }}</td>
    </tr>
    {% endif %}
    {% if header.p1 %}
    <tr>
        <td class="info-label">Data wystawienia:</td>
        <td class="info-value">{{ header.p1 }}</td>
    </tr>
    {% endif %}
    {% if header.p1m %}
    <tr>
        <td class="info-label">Miejsce wystawienia:</td>
        <td class="info-value">{{ header.p1m }}</td>
    </tr>
    {% endif %}
    {% if header.p4a %}
    <tr>
        <td class="info-label">Data dokonania nabycia:</td>
        <td class="info-value">{{ header.p4a }}</td>
    </tr>
    {% endif %}
    {% if header.kod_waluty %}
    <tr>
        <td class="info-label">Waluta:</td>
        <td class="info-value">{{ header.kod_waluty }}</td>
    </tr>
    {% endif %}
</table>

<!-- Parties: nabywca (skupujący) | rolnik (dostawca) -->
{% macro rr_party(p, title) %}
<p class="party-title">{{ title }}</p>
<p class="party-name">{{ p.nazwa or "—" }}</p>
{% if p.nip %}<p class="party-detail">NIP: <strong>{{ p.nip }}</strong></p>{% endif %}
{% if p.nr_id %}<p class="party-detail">ID: {{ p.nr_id }}</p>{% endif %}
{% if p.kod_kraju %}<p class="party-detail">Kraj: {{ p.kod_kraju }}</p>{% endif %}
{% if p.adres_l1 %}<p class="party-detail">{{ p.adres_l1 }}{% if p.adres_l2 %}, {{ p.adres_l2 }}{% endif %}</p>{% endif %}
{% if p.nr_klienta %}<p class="party-detail">Nr kontrahenta: {{ p.nr_klienta }}</p>{% endif %}
{% if p.email %}<p class="party-detail">Email: {{ p.email }}</p>{% endif %}
{% if p.telefon %}<p class="party-detail">Tel: {{ p.telefon }}</p>{% endif %}
{% endmacro %}
<table class="parties-table">
    <tr>
        <td class="party-cell">{{ rr_party(buyer, 'Nabywca (skupujący)') }}</td>
        <td class="party-cell">{{ rr_party(farmer, 'Rolnik ryczałtowy (dostawca)') }}</td>
    </tr>
</table>

<!-- Correction info -->
{% if header.przyczyna_korekty or dane_korygowanej or header.nr_fa_korygowany or podmiot_korekty %}
<div class="rr-section">
    <p class="rr-section-title">Dane korekty</p>
    <table class="rr-table">
        {% if header.przyczyna_korekty %}
        <tr><td class="rr-label">Przyczyna korekty:</td><td class="rr-value">{{ header.przyczyna_korekty }}</td></tr>
        {% endif %}
        {% if header.typ_korekty %}
        {% set typ_map = {'1': 'Korekta wartości', '2': 'Korekta danych', '3': 'Korekta wartości i danych'} %}
        <tr><td class="rr-label">Typ korekty:</td><td class="rr-value">{{ typ_map.get(header.typ_korekty, header.typ_korekty) }}</td></tr>
        {% endif %}
        {% if header.nr_fa_korygowany %}
        <tr><td class="rr-label">Poprawny nr faktury korygowanej:</td><td class="rr-value">{{ header.nr_fa_korygowany }}</td></tr>
        {% endif %}
        {% for d in dane_korygowanej %}
        <tr><td class="rr-label">Faktura korygowana:</td><td class="rr-value">{{ d.nr_ksef or d.nr_faktury }}{% if d.data_wyst %} ({{ d.data_wyst }}){% endif %}{% if d.nr_ksef_n == '1' %} — poza KSeF{% endif %}</td></tr>
        {% endfor %}
        {% if podmiot_korekty.seller_k %}
        <tr><td class="rr-label">Nabywca przed korektą:</td><td class="rr-value">{{ podmiot_korekty.seller_k.nazwa }}{% if podmiot_korekty.seller_k.nip %} (NIP: {{ podmiot_korekty.seller_k.nip }}){% endif %}</td></tr>
        {% endif %}
        {% if podmiot_korekty.buyer_k %}
        <tr><td class="rr-label">Rolnik przed korektą:</td><td class="rr-value">{{ podmiot_korekty.buyer_k.nazwa }}{% if podmiot_korekty.buyer_k.nip %} (NIP: {{ podmiot_korekty.buyer_k.nip }}){% endif %}</td></tr>
        {% endif %}
    </table>
</div>
{% endif %}

<!-- Items table -->
{% if items %}
<div class="rr-section">
    <p class="rr-section-title">Pozycje faktury</p>
    <table class="items-table">
        <thead>
            <tr>
                <th class="col-no">Lp.</th>
                <th class="col-name">Nazwa (rodzaj) produktu rolnego / usługi</th>
                <th class="col-unit">J.m.</th>
                <th class="col-qty">Ilość</th>
                <th class="col-price">Cena jedn.<br/>netto</th>
                <th class="col-net">Wartość<br/>netto</th>
                <th class="col-vat">Stawka<br/>zwrotu</th>
                <th class="col-net">Kwota<br/>zwrotu</th>
                <th class="col-net">Wartość<br/>brutto</th>
            </tr>
        </thead>
        <tbody>
            {% for item in items %}
            <tr>
                <td class="col-no">{{ item.nr or loop.index }}</td>
                <td class="col-name">{{ item.p5 or "—" }}{% if item.p6c %}<br/><span style="color:#777;">{{ item.p6c }}</span>{% endif %}</td>
                <td class="col-unit">{{ item.p6a or "" }}</td>
                <td class="col-qty">{{ item.p6b | fmt_amt if item.p6b else "" }}</td>
                <td class="col-price">{{ item.p7 | fmt_amt if item.p7 else "" }}</td>
                <td class="col-net">{{ item.p8 | fmt_amt if item.p8 else "" }}</td>
                <td class="col-vat">{{ item.p9 }}{% if item.p9 %}%{% endif %}</td>
                <td class="col-net">{{ item.p10 | fmt_amt if item.p10 else "" }}</td>
                <td class="col-net">{{ item.p11 | fmt_amt if item.p11 else "" }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

<!-- RR totals -->
<div class="rr-section">
    <table class="totals-table">
        {% if fa_rr.p11_1 %}
        <tr>
            <td class="total-label">Wartość nabytych produktów/usług (netto):</td>
            <td class="total-value">{{ fa_rr.p11_1 | fmt_amt }} {{ header.kod_waluty or "PLN" }}</td>
        </tr>
        {% endif %}
        {% if fa_rr.p11_2 %}
        <tr>
            <td class="total-label">Kwota zryczałtowanego zwrotu podatku:</td>
            <td class="total-value">{{ fa_rr.p11_2 | fmt_amt }} {{ header.kod_waluty or "PLN" }}</td>
        </tr>
        {% endif %}
        {% if fa_rr.p12_1 or header.p15 %}
        <tr class="total-grand">
            <td class="total-label">Kwota należności ogółem:</td>
            <td class="total-value">{{ (fa_rr.p12_1 or header.p15) | fmt_amt }} {{ header.kod_waluty or "PLN" }}</td>
        </tr>
        {% endif %}
        {% if fa_rr.p12_2 %}
        <tr>
            <td class="total-label">Kwota należności ogółem (słownie):</td>
            <td class="total-value">{{ fa_rr.p12_2 }}</td>
        </tr>
        {% endif %}
    </table>
</div>

<!-- Rozliczenie -->
{% if rozliczenie %}
<div class="rr-section">
    <p class="rr-section-title">Rozliczenie</p>
    <table class="rr-table">
        {% for o in rozliczenie.obciazenia | default([]) %}
        <tr><td class="rr-label">Obciążenie:</td><td class="rr-value">{{ o.kwota | fmt_amt }} — {{ o.powod }}</td></tr>
        {% endfor %}
        {% for o in rozliczenie.odliczenia | default([]) %}
        <tr><td class="rr-label">Odliczenie:</td><td class="rr-value">{{ o.kwota | fmt_amt }} — {{ o.powod }}</td></tr>
        {% endfor %}
        {% if rozliczenie.do_zaplaty %}
        <tr><td class="rr-label">Do zapłaty:</td><td class="rr-value">{{ rozliczenie.do_zaplaty | fmt_amt }}</td></tr>
        {% endif %}
        {% if rozliczenie.do_rozliczenia %}
        <tr><td class="rr-label">Do rozliczenia:</td><td class="rr-value">{{ rozliczenie.do_rozliczenia | fmt_amt }}</td></tr>
        {% endif %}
    </table>
</div>
{% endif %}

<!-- Payment -->
{% if payment and (payment.forma or payment.rachunki) %}
<div class="rr-section">
    <p class="rr-section-title">Płatność</p>
    <table class="rr-table">
        {% if payment.forma %}
        <tr><td class="rr-label">Forma płatności:</td><td class="rr-value">{{ payment.forma | payment_method }}</td></tr>
        {% endif %}
        {% if payment.ipksef %}
        <tr><td class="rr-label">Identyfikator płatności KSeF:</td><td class="rr-value">{{ payment.ipksef }}</td></tr>
        {% endif %}
        {% if payment.link_do_platnosci %}
        <tr><td class="rr-label">Link do płatności:</td><td class="rr-value">{{ payment.link_do_platnosci }}</td></tr>
        {% endif %}
        {% for r in payment.rachunki | default([]) %}
        {% if r.nr_rb %}
        <tr><td class="rr-label">Rachunek bankowy:</td><td class="rr-value">{{ r.nr_rb }}{% if r.swift %} (SWIFT: {{ r.swift }}){% endif %}{% if r.nazwa_banku %} — {{ r.nazwa_banku }}{% endif %}</td></tr>
        {% endif %}
        {% endfor %}
    </table>
</div>
{% endif %}

<!-- Payment documents (DokumentZaplaty) -->
{% if fa_rr.dokumenty_zaplaty %}
<div class="rr-section">
    <p class="rr-section-title">Dokumenty zapłaty</p>
    <table class="rr-table">
        {% for d in fa_rr.dokumenty_zaplaty %}
        <tr><td class="rr-label">Dokument:</td><td class="rr-value">{{ d.nr }}{% if d.data %} ({{ d.data }}){% endif %}</td></tr>
        {% endfor %}
    </table>
</div>
{% endif %}

<!-- Additional descriptions -->
{% if dodatkowy_opis %}
<div class="rr-section">
    <p class="rr-section-title">Informacje dodatkowe</p>
    <table class="rr-table">
        {% for o in dodatkowy_opis %}
        <tr><td class="rr-label">{{ o.klucz }}</td><td class="rr-value">{{ o.wartosc }}</td></tr>
        {% endfor %}
    </table>
</div>
{% endif %}

<!-- Footer metadata -->
{% if footer_data.informacje %}
{% for info in footer_data.informacje %}
<p style="font-size: 8pt; margin-top: 2mm;">{{ info }}</p>
{% endfor %}
{% endif %}
{% if header.system_info %}
<p style="font-size: 7pt; color: #888888; margin-top: 2mm;">System: {{ header.system_info }}</p>
{% endif %}
{% if header.data_wytworzenia %}
<p style="font-size: 7pt; color: #888888; margin-top: 2mm;">
    Data wytworzenia faktury: {{ header.data_wytworzenia }}
</p>
{% endif %}

</body>
</html>
