<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
    @page {
        size: A4;
        margin: 12mm 12mm 18mm 12mm;

        @frame footer_frame {
            -pdf-frame-content: page-footer-content;
            left: 12mm;
            width: 186mm;
            bottom: 0mm;
            height: 12mm;
        }
    }

    {% if font_paths.regular %}
    @font-face {
        font-family: "{{ font_name }}";
        src: url("{{ font_paths.regular }}");
    }
    {% if font_paths.bold %}
    @font-face {
        font-family: "{{ font_name }}";
        font-weight: bold;
        src: url("{{ font_paths.bold }}");
    }
    {% endif %}
    {% endif %}
    body {
        font-family: "{{ font_name }}", "{{ font_name_bold }}", "DejaVuSans", "Arial", "Helvetica", sans-serif;
        font-size: 9pt;
        line-height: 1.3;
        color: #000000;
        margin: 0;
        padding: 0;
    }

    /* KSeF branding */
    .ksef-branding {
        font-size: 8pt;
        font-weight: bold;
        color: #333333;
        margin-bottom: 3mm;
    }
    .ksef-e { color: red; }

    /* Title */
    .invoice-title {
        font-size: 14pt;
        font-weight: bold;
        text-align: center;
        margin-bottom: 2mm;
    }
    .invoice-subtitle {
        font-size: 11pt;
        font-weight: bold;
        text-align: center;
        margin-bottom: 3mm;
    }

    /* Title + QR layout */
    .title-qr-table {
        width: 100%;
        margin-bottom: 2mm;
    }
    .title-qr-table td {
        vertical-align: top;
        padding: 0;
    }
    .title-qr-table .title-col {
        width: auto;
    }
    .title-qr-table .qr-col {
        width: 35mm;
        text-align: right;
    }
    .qr-image {
        width: 30mm;
        height: 30mm;
    }
    .qr-label {
        font-size: 7pt;
        text-align: center;
        word-break: break-all;
        margin-top: 1mm;
    }

    /* Invoice info fields */
    .info-table {
        width: 100%;
        margin-bottom: 2mm;
    }
    .info-table td {
        padding: 1px 0;
        vertical-align: top;
    }
    .info-label {
        font-size: 9pt;
        width: 70mm;
    }
    .info-value {
        font-size: 9pt;
        font-weight: bold;
    }

    /* Section headers */
    .section-header {
        font-size: 10pt;
        font-weight: bold;
        margin-top: 4mm;
        margin-bottom: 2mm;
    }
    .sub-header {
        font-size: 8pt;
        font-weight: bold;
        margin-top: 2mm;
        margin-bottom: 1mm;
    }

    /* Parties (seller/buyer) */
    .parties-table {
        width: 100%;
        border: 0.5pt solid grey;
        border-collapse: collapse;
        margin-bottom: 4mm;
    }
    .parties-table td {
        width: 50%;
        vertical-align: top;
        padding: 5px;
        border: 0.5pt solid grey;
        font-size: 9pt;
        line-height: 1.4;
    }
    .party-title {
        font-weight: bold;
        margin-bottom: 2px;
    }

    /* Items table */
    .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 4mm;
    }
    .items-table th {
        background-color: #e0e0e0;
        font-size: 7pt;
        font-weight: bold;
        text-align: center;
        padding: 2px;
        border: 0.5pt solid grey;
        vertical-align: middle;
    }
    .items-table td {
        font-size: 7pt;
        padding: 2px;
        border: 0.5pt solid grey;
        vertical-align: middle;
    }
    .td-right { text-align: right; }
    .td-center { text-align: center; }
    .td-left { text-align: left; }

    /* VAT summary table */
    .vat-table {
        border-collapse: collapse;
        margin-bottom: 4mm;
    }
    .vat-table th {
        background-color: #e0e0e0;
        font-size: 7pt;
        font-weight: bold;
        text-align: center;
        padding: 3px;
        border: 0.5pt solid grey;
        width: 40mm;
    }
    .vat-table td {
        font-size: 7pt;
        padding: 3px;
        border: 0.5pt solid grey;
        width: 40mm;
    }

    /* Total amount */
    .total-table {
        width: 100%;
        margin-bottom: 4mm;
    }
    .total-table td {
        padding-top: 6px;
        border-top: 1pt solid black;
    }
    .total-label {
        font-size: 11pt;
        font-weight: bold;
        text-align: right;
    }
    .total-value {
        font-size: 11pt;
        font-weight: bold;
        text-align: right;
    }
    .exchange-rate {
        font-size: 8pt;
        text-align: right;
    }

    /* Payment section */
    .payment-table {
        width: 100%;
    }
    .payment-table td {
        padding: 1px 0;
        vertical-align: top;
    }
    .payment-label {
        font-size: 8pt;
        font-weight: bold;
        width: 50mm;
    }
    .payment-value {
        font-size: 8pt;
    }

    /* Annotations */
    .annotation-table {
        width: 100%;
    }
    .annotation-table td {
        padding: 1px 0;
        vertical-align: top;
    }
    .annotation-label {
        font-size: 8pt;
        font-weight: bold;
        width: 60mm;
    }
    .annotation-value {
        font-size: 8pt;
    }

    /* Key-value table (DodatkowyOpis, etc.) */
    .kv-table {
        border-collapse: collapse;
        margin-bottom: 4mm;
    }
    .kv-table th {
        background-color: #e0e0e0;
        font-size: 7pt;
        font-weight: bold;
        text-align: center;
        padding: 3px;
        border: 0.5pt solid grey;
    }
    .kv-table td {
        font-size: 7pt;
        padding: 3px;
        border: 0.5pt solid grey;
    }

    /* Small text */
    .small-text {
        font-size: 8pt;
    }

    /* Footer info */
    .footer-info {
        font-size: 8pt;
        margin-top: 2mm;
    }
    .footer-registry {
        font-size: 8pt;
    }

    /* Page footer stamp - rendered in @frame on every page */
    .page-footer {
        font-size: 6pt;
        color: grey;
        text-align: center;
        padding-top: 2mm;
        border-top: 0.5pt solid #cccccc;
    }
</style>
</head>
<body>

{# ===== PAGE FOOTER STAMP (running footer - every page) ===== #}
<div id="page-footer-content">
    <div class="page-footer">
        Wygenerowane przez KSeF Monitor v0.3 | {{ generation_stamp }}
    </div>
</div>

{# ===== KSeF BRANDING ===== #}
<div class="ksef-branding">
    Krajowy System <span class="ksef-e">e</span>-Faktur
    (KS<span class="ksef-e">e</span>F){% if ksef_number %}: {{ ksef_number }}{% endif %}
</div>

{# ===== TITLE + QR CODE ===== #}
<table class="title-qr-table">
<tr>
    <td class="title-col">
        <div class="invoice-title">{{ invoice_type_title }}</div>
        {% if header.kod_formularza %}
        <div class="invoice-subtitle">{{ header.kod_formularza }} ({{ header.wariant }})</div>
        {% endif %}

        {# Invoice info #}
        <table class="info-table">
        {% if header.kod_waluty %}
        <tr><td class="info-label">Kod waluty:</td><td class="info-value">{{ header.kod_waluty }}</td></tr>
        {% endif %}
        {% if header.p2 %}
        <tr><td class="info-label">Numer faktury:</td><td class="info-value">{{ header.p2 }}</td></tr>
        {% endif %}
        {% if header.p1 %}
        <tr><td class="info-label">Data wystawienia:</td><td class="info-value">{{ header.p1 }}</td></tr>
        {% endif %}
        {% if header.p1m %}
        <tr><td class="info-label">Miejsce wystawienia:</td><td class="info-value">{{ header.p1m }}</td></tr>
        {% endif %}
        {% if header.p6 %}
        <tr><td class="info-label">Data dokonania dostawy / wykonania usługi:</td><td class="info-value">{{ header.p6 }}</td></tr>
        {% endif %}
        {% if header.p6_od %}
        <tr><td class="info-label">Okres faktury od:</td><td class="info-value">{{ header.p6_od }}</td></tr>
        {% endif %}
        {% if header.p6_do %}
        <tr><td class="info-label">Okres faktury do:</td><td class="info-value">{{ header.p6_do }}</td></tr>
        {% endif %}
        </table>
    </td>
    {% if qr_code_data_uri %}
    <td class="qr-col">
        <img src="{{ qr_code_data_uri }}" class="qr-image" />
        {% if ksef_number %}
        <div class="qr-label">{{ ksef_number }}</div>
        {% endif %}
    </td>
    {% endif %}
</tr>
</table>

{# ===== SELLER / BUYER ===== #}
{% macro party_block(party, title) %}
<div class="party-title">{{ title }}</div>
{% if party.nip %}
NIP: {% if party.prefiks %}{{ party.prefiks }} {% endif %}<b>{{ party.nip }}</b><br/>
{% endif %}
{% if party.kod_ue and party.nr_vat_ue %}
VAT UE: {{ party.kod_ue }} {{ party.nr_vat_ue }}<br/>
{% endif %}
{% if party.nr_id %}
ID: {{ party.kod_kraju_id | default('') }} {{ party.nr_id }}<br/>
{% endif %}
{% if party.nazwa %}
{{ party.nazwa }}<br/>
{% endif %}
{% if party.kod_kraju %}
Kod kraju: {{ party.kod_kraju }}<br/>
{% endif %}
{% if party.adres_l1 %}
{{ party.adres_l1 }}{% if party.adres_l2 %} {{ party.adres_l2 }}{% endif %}<br/>
{% endif %}
{% if party.nr_eori %}
EORI: {{ party.nr_eori }}<br/>
{% endif %}
{% if party.gln %}
GLN: {{ party.gln }}<br/>
{% endif %}
{% if party.email %}
Email: {{ party.email }}<br/>
{% endif %}
{% if party.telefon %}
Tel: {{ party.telefon }}<br/>
{% endif %}
{% endmacro %}

<table class="parties-table">
<tr>
    <td>{{ party_block(seller, 'SPRZEDAWCA') }}</td>
    <td>{{ party_block(buyer, 'NABYWCA') }}</td>
</tr>
</table>

{# ===== PODMIOT3 (additional parties) ===== #}
{% for p3 in podmiot3 %}
<table class="parties-table">
<tr>
    <td colspan="2">
        {% set role = p3.opis_roli or p3.rola_inna | default('') %}
        {{ party_block(p3, 'PODMIOT TRZECI' + (' &mdash; ' + role if role else '')) }}
        {% if p3.udzial %}
        Udział: {{ p3.udzial }}%<br/>
        {% endif %}
        {% if p3.nr_klienta %}
        Nr klienta: {{ p3.nr_klienta }}<br/>
        {% endif %}
    </td>
</tr>
</table>
{% endfor %}

{# ===== CORRECTION INFO ===== #}
{% if header.przyczyna_korekty or dane_korygowanej %}
<div class="section-header">Dane korekty</div>
<table class="payment-table">
{% if header.przyczyna_korekty %}
<tr><td class="payment-label">Przyczyna korekty:</td><td class="payment-value">{{ header.przyczyna_korekty }}</td></tr>
{% endif %}
{% if header.typ_korekty %}
{% set typ_map = {'1': 'Korekta wartości', '2': 'Korekta danych', '3': 'Korekta wartości i danych'} %}
<tr><td class="payment-label">Typ korekty:</td><td class="payment-value">{{ typ_map.get(header.typ_korekty, header.typ_korekty) }}</td></tr>
{% endif %}
{% if header.nr_fa_korekty %}
<tr><td class="payment-label">Nr faktury korygowanej:</td><td class="payment-value">{{ header.nr_fa_korekty }}</td></tr>
{% endif %}
{% for d in dane_korygowanej %}
{% set nr = d.nr_ksef or d.nr_faktury | default('') %}
<tr><td class="payment-label">Faktura korygowana:</td><td class="payment-value">{{ nr }}{% if d.data_wyst %} ({{ d.data_wyst }}){% endif %}</td></tr>
{% endfor %}
</table>
{% endif %}

{# ===== ITEMS TABLE ===== #}
{% if items %}
<table class="items-table">
<thead>
<tr>
    <th>Lp.</th>
    <th>Nazwa (rodzaj) towaru lub usługi</th>
    {% if has_col.indeks %}<th>Indeks</th>{% endif %}
    {% if has_col.p8a %}<th>J.m.</th>{% endif %}
    {% if has_col.p8b %}<th>Ilość</th>{% endif %}
    {% if has_col.p9a %}<th>Cena jedn.<br/>netto</th>{% endif %}
    {% if has_col.p9b %}<th>Cena jedn.<br/>brutto</th>{% endif %}
    {% if has_col.p10 %}<th>Rabaty/<br/>opusty</th>{% endif %}
    {% if has_col.p11 %}<th>Wart.<br/>netto</th>{% endif %}
    {% if has_col.p11a %}<th>Wart.<br/>brutto</th>{% endif %}
    {% if has_col.p11vat %}<th>Kwota VAT</th>{% endif %}
    {% if has_col.p12 %}<th>Stawka<br/>VAT</th>{% endif %}
    {% if has_col.p6a %}<th>Data<br/>dost.</th>{% endif %}
</tr>
</thead>
<tbody>
{% for item in items %}
<tr>
    <td class="td-center">{{ item.nr | default('') }}</td>
    <td class="td-left">{{ item.p7 | default('') }}</td>
    {% if has_col.indeks %}<td class="td-left">{{ item.indeks | default('') }}</td>{% endif %}
    {% if has_col.p8a %}<td class="td-center">{{ item.p8a | default('') }}</td>{% endif %}
    {% if has_col.p8b %}<td class="td-right">{{ item.p8b | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p9a %}<td class="td-right">{{ item.p9a | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p9b %}<td class="td-right">{{ item.p9b | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p10 %}<td class="td-right">{{ item.p10 | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p11 %}<td class="td-right">{{ item.p11 | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p11a %}<td class="td-right">{{ item.p11a | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p11vat %}<td class="td-right">{{ item.p11vat | default('') | fmt_amt }}</td>{% endif %}
    {% if has_col.p12 %}<td class="td-center">{{ item.p12 | default('') | vat_label }}</td>{% endif %}
    {% if has_col.p6a %}<td class="td-center">{{ item.p6a | default('') }}</td>{% endif %}
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{# ===== VAT SUMMARY ===== #}
{% if vat_rows %}
<div class="section-header">Podliczenie VAT</div>
<table class="vat-table">
<thead>
<tr>
    <th>Stawka VAT</th>
    <th>Wartość netto</th>
    <th>Kwota VAT</th>
    {% if has_vat_w %}<th>Kwota VAT (PLN)</th>{% endif %}
</tr>
</thead>
<tbody>
{% for row in vat_rows %}
<tr>
    <td class="td-center">{{ row.label }}</td>
    <td class="td-right">{{ row.net | fmt_amt }}</td>
    <td class="td-right">{{ row.vat | fmt_amt }}</td>
    {% if has_vat_w %}<td class="td-right">{{ row.vat_w | fmt_amt }}</td>{% endif %}
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{# ===== TOTAL AMOUNT ===== #}
{% if header.p15 %}
<table class="total-table">
<tr>
    <td class="total-label">{{ total_label }}</td>
    <td class="total-value">{{ header.p15 | fmt_amt }}{% if header.kod_waluty %} {{ header.kod_waluty }}{% endif %}</td>
</tr>
</table>
{% if header.kurs_waluty_z and header.kod_waluty %}
<div class="exchange-rate">Kurs waluty: {{ header.kurs_waluty_z }} PLN/{{ header.kod_waluty }}</div>
{% endif %}
{% endif %}

{# ===== ROZLICZENIE (surcharges/deductions) ===== #}
{% if rozliczenie %}
<div class="section-header">Rozliczenie</div>
<table class="payment-table">
{% for o in rozliczenie.obciazenia | default([]) %}
<tr><td class="payment-label">Obciążenie:</td><td class="payment-value">{{ o.kwota | default('') | fmt_amt }} &mdash; {{ o.powod | default('') }}</td></tr>
{% endfor %}
{% if rozliczenie.suma_obciazen %}
<tr><td class="payment-label">Suma obciążeń:</td><td class="payment-value">{{ rozliczenie.suma_obciazen | fmt_amt }}</td></tr>
{% endif %}
{% for o in rozliczenie.odliczenia | default([]) %}
<tr><td class="payment-label">Odliczenie:</td><td class="payment-value">{{ o.kwota | default('') | fmt_amt }} &mdash; {{ o.powod | default('') }}</td></tr>
{% endfor %}
{% if rozliczenie.suma_odliczen %}
<tr><td class="payment-label">Suma odliczeń:</td><td class="payment-value">{{ rozliczenie.suma_odliczen | fmt_amt }}</td></tr>
{% endif %}
{% if rozliczenie.do_zaplaty %}
<tr><td class="payment-label">Do zapłaty:</td><td class="payment-value">{{ rozliczenie.do_zaplaty | fmt_amt }}</td></tr>
{% endif %}
{% if rozliczenie.do_rozliczenia %}
<tr><td class="payment-label">Do rozliczenia:</td><td class="payment-value">{{ rozliczenie.do_rozliczenia | fmt_amt }}</td></tr>
{% endif %}
</table>
{% endif %}

{# ===== ADVANCE INVOICES + PARTIAL ADVANCES ===== #}
{% if faktury_zaliczkowe %}
<div class="section-header">Faktury zaliczkowe</div>
{% for fz in faktury_zaliczkowe %}
<div class="small-text">{{ fz.nr_ksef or fz.nr_faktury | default('') }}</div>
{% endfor %}
{% endif %}

{% if zaliczki_czesciowe %}
<div class="section-header">Zaliczki częściowe</div>
{% for zc in zaliczki_czesciowe %}
<div class="small-text">
{% if zc.p15z %}Kwota: {{ zc.p15z | fmt_amt }}{% endif %}
{% if zc.p6z %} | Data: {{ zc.p6z }}{% endif %}
{% if zc.kurs_waluty %} | Kurs: {{ zc.kurs_waluty }}{% endif %}
</div>
{% endfor %}
{% endif %}

{# ===== PAYMENT ===== #}
{% if payment %}
<div class="section-header">Płatność</div>
<table class="payment-table">
{% if payment.zaplacono == '1' %}
<tr><td class="payment-label">Zapłacono:</td><td class="payment-value">Tak</td></tr>
{% if payment.data_zaplaty %}
<tr><td class="payment-label">Data zapłaty:</td><td class="payment-value">{{ payment.data_zaplaty }}</td></tr>
{% endif %}
{% endif %}
{% if payment.forma %}
<tr><td class="payment-label">Forma płatności:</td><td class="payment-value">{{ payment.forma | payment_method }}</td></tr>
{% endif %}
{% if payment.platnosc_inna == '1' %}
<tr><td class="payment-label">Inna forma płatności:</td><td class="payment-value">{{ payment.opis_platnosci | default('') }}</td></tr>
{% endif %}
{% for termin in payment.terminy | default([]) %}
<tr><td class="payment-label">Termin płatności:</td><td class="payment-value">{{ termin.termin | default('') }}{% if termin.opis_ilosc %} ({{ termin.opis_ilosc }} {{ termin.opis_jednostka | default('') }}){% endif %}</td></tr>
{% endfor %}
{% for r in payment.rachunki | default([]) %}
<tr><td class="payment-label">Rachunek bankowy:</td><td class="payment-value">{{ r.nr_rb | default('') }}{% if r.swift %} (SWIFT: {{ r.swift }}){% endif %}</td></tr>
{% if r.nazwa_banku %}
<tr><td class="payment-label">Bank:</td><td class="payment-value">{{ r.nazwa_banku }}</td></tr>
{% endif %}
{% if r.opis %}
<tr><td class="payment-label">Opis rachunku:</td><td class="payment-value">{{ r.opis }}</td></tr>
{% endif %}
{% endfor %}
{% for r in payment.rachunki_faktora | default([]) %}
<tr><td class="payment-label">Rachunek faktora:</td><td class="payment-value">{{ r.nr_rb | default('') }}{% if r.swift %} (SWIFT: {{ r.swift }}){% endif %}</td></tr>
{% if r.nazwa_banku %}
<tr><td class="payment-label">Bank faktora:</td><td class="payment-value">{{ r.nazwa_banku }}</td></tr>
{% endif %}
{% endfor %}
</table>
{% if payment.zaplaty_czesciowe %}
<div class="sub-header">Zapłaty częściowe</div>
<table class="payment-table">
{% for zc in payment.zaplaty_czesciowe %}
<tr><td class="payment-label">Kwota:</td><td class="payment-value">{{ zc.kwota | default('') | fmt_amt }}</td></tr>
<tr><td class="payment-label">Data:</td><td class="payment-value">{{ zc.data | default('') }}</td></tr>
{% if zc.forma %}
<tr><td class="payment-label">Forma:</td><td class="payment-value">{{ zc.forma | payment_method }}</td></tr>
{% endif %}
{% if zc.platnosc_inna == '1' %}
<tr><td class="payment-label">Inna forma:</td><td class="payment-value">{{ zc.opis | default('') }}</td></tr>
{% endif %}
{% endfor %}
</table>
{% endif %}
{% if payment.skonto_warunki %}
<table class="payment-table">
<tr><td class="payment-label">Warunki skonta:</td><td class="payment-value">{{ payment.skonto_warunki }}</td></tr>
{% if payment.skonto_wysokosc %}
<tr><td class="payment-label">Wysokość skonta:</td><td class="payment-value">{{ payment.skonto_wysokosc }}</td></tr>
{% endif %}
</table>
{% endif %}
{% endif %}

{# ===== ANNOTATIONS ===== #}
{% if annotations %}
{% set ann_items = [] %}
{% if annotations.p16 %}{% set _ = ann_items.append(('Metoda kasowa', annotations.p16)) %}{% endif %}
{% if annotations.p17 %}{% set _ = ann_items.append(('Samofakturowanie', annotations.p17)) %}{% endif %}
{% if annotations.p18 %}{% set _ = ann_items.append(('Odwrotne obciażenie', annotations.p18)) %}{% endif %}
{% if annotations.p18a %}{% set _ = ann_items.append(('Mechanizm podzielonej płatności', annotations.p18a)) %}{% endif %}
{% if annotations.p23 %}{% set _ = ann_items.append(('Procedura uproszczona (drugi sprzedawca)', annotations.p23)) %}{% endif %}
{% if ann_items or annotations.p19 == '1' or annotations.p_pmarzy == '1' or annotations.p22 == '1' %}
<div class="section-header">Adnotacje</div>
<table class="annotation-table">
{% for label, val in ann_items %}
<tr>
    <td class="annotation-label">{{ label }}:</td>
    <td class="annotation-value">{% if val == '1' %}Tak{% elif val == '2' %}Nie{% else %}{{ val }}{% endif %}</td>
</tr>
{% endfor %}
{% if annotations.p19 == '1' %}
<tr><td class="annotation-label">Zwolnienie od podatku:</td><td class="annotation-value">Tak</td></tr>
{% if annotations.p19a %}
<tr><td class="annotation-label">&nbsp;&nbsp;Przepis ustawy:</td><td class="annotation-value">{{ annotations.p19a }}</td></tr>
{% endif %}
{% if annotations.p19b %}
<tr><td class="annotation-label">&nbsp;&nbsp;Dyrektywa UE:</td><td class="annotation-value">{{ annotations.p19b }}</td></tr>
{% endif %}
{% if annotations.p19c %}
<tr><td class="annotation-label">&nbsp;&nbsp;Inna podstawa:</td><td class="annotation-value">{{ annotations.p19c }}</td></tr>
{% endif %}
{% endif %}
{# Margin scheme (PMarzy) #}
{% if annotations.p_pmarzy == '1' %}
<tr><td class="annotation-label">Procedura marży:</td><td class="annotation-value">Tak</td></tr>
{% if annotations.p_pmarzy_2 == '1' %}
<tr><td class="annotation-label">&nbsp;&nbsp;Usługi turystyki:</td><td class="annotation-value">Tak</td></tr>
{% endif %}
{% if annotations.p_pmarzy_3_1 == '1' %}
<tr><td class="annotation-label">&nbsp;&nbsp;Towary używane:</td><td class="annotation-value">Tak</td></tr>
{% endif %}
{% if annotations.p_pmarzy_3_2 == '1' %}
<tr><td class="annotation-label">&nbsp;&nbsp;Dzieła sztuki:</td><td class="annotation-value">Tak</td></tr>
{% endif %}
{% if annotations.p_pmarzy_3_3 == '1' %}
<tr><td class="annotation-label">&nbsp;&nbsp;Przedmioty kolekcjonerskie i antyki:</td><td class="annotation-value">Tak</td></tr>
{% endif %}
{% endif %}
{# New transport vehicles #}
{% if annotations.p22 == '1' %}
<tr><td class="annotation-label">Nowy środek transportu:</td><td class="annotation-value">Tak</td></tr>
{% if annotations.p_42_5 == '1' %}
<tr><td class="annotation-label">&nbsp;&nbsp;Art. 42 ust. 5:</td><td class="annotation-value">Tak</td></tr>
{% endif %}
{% for veh in annotations.nowe_srodki | default([]) %}
{% set parts = [] %}
{% if veh.marka %}{% set _ = parts.append(veh.marka) %}{% endif %}
{% if veh.model %}{% set _ = parts.append(veh.model) %}{% endif %}
{% if veh.nr_id %}{% set _ = parts.append('Nr ID: ' + veh.nr_id) %}{% endif %}
{% if veh.rok_prod %}{% set _ = parts.append('Rok: ' + veh.rok_prod) %}{% endif %}
{% if veh.pojemnosc %}{% set _ = parts.append('Poj.: ' + veh.pojemnosc + ' cm³') %}{% endif %}
{% if veh.przebieg %}{% set _ = parts.append('Przebieg: ' + veh.przebieg + ' km') %}{% endif %}
{% if parts %}
<tr><td class="annotation-label">&nbsp;&nbsp;Pojazd:</td><td class="annotation-value">{{ parts | join(', ') }}</td></tr>
{% endif %}
{% endfor %}
{% endif %}
</table>
{% endif %}
{% endif %}

{# ===== DODATKOWY OPIS ===== #}
{% if dodatkowy_opis %}
<div class="section-header">Informacje dodatkowe</div>
<table class="kv-table">
<thead>
<tr><th style="width: 50mm;">Klucz</th><th>Wartość</th></tr>
</thead>
<tbody>
{% for o in dodatkowy_opis %}
<tr><td>{{ o.klucz | default('') }}</td><td>{{ o.wartosc | default('') }}</td></tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{# ===== WARUNKI TRANSAKCJI ===== #}
{% if payment.warunki_transakcji is defined and payment.warunki_transakcji %}
{% set wt = payment.warunki_transakcji %}
<div class="section-header">Warunki transakcji</div>
<table class="payment-table">
{% for u in wt.umowy | default([]) %}
<tr><td class="payment-label">Umowa:</td><td class="payment-value">{{ u.numer | default('') }}{% if u.data %} ({{ u.data }}){% endif %}</td></tr>
{% endfor %}
{% for z in wt.zamowienia | default([]) %}
<tr><td class="payment-label">Zamówienie:</td><td class="payment-value">{{ z.numer | default('') }}{% if z.data %} ({{ z.data }}){% endif %}</td></tr>
{% endfor %}
{% for p in wt.nr_partii | default([]) %}
<tr><td class="payment-label">Nr partii towaru:</td><td class="payment-value">{{ p }}</td></tr>
{% endfor %}
{% if wt.warunki_dostawy %}
<tr><td class="payment-label">Warunki dostawy:</td><td class="payment-value">{{ wt.warunki_dostawy }}</td></tr>
{% endif %}
{% if wt.kurs_umowny %}
<tr><td class="payment-label">Kurs umowny:</td><td class="payment-value">{{ wt.kurs_umowny }} {{ wt.waluta_umowna | default('') }}</td></tr>
{% endif %}
{% for tr in wt.transport | default([]) %}
{% if tr.rodzaj or tr.opis_innego %}
<tr><td class="payment-label">Transport:</td><td class="payment-value">{% if tr.transport_inny == '1' %}{{ tr.opis_innego | default('inny') }}{% else %}{{ tr.rodzaj | default('') }}{% endif %}</td></tr>
{% endif %}
{% if tr.przewoznik_nazwa %}
<tr><td class="payment-label">&nbsp;&nbsp;Przewoźnik:</td><td class="payment-value">{{ tr.przewoznik_nazwa }}</td></tr>
{% endif %}
{% if tr.nr_zlecenia %}
<tr><td class="payment-label">&nbsp;&nbsp;Nr zlecenia:</td><td class="payment-value">{{ tr.nr_zlecenia }}</td></tr>
{% endif %}
{% if tr.opis_ladunku or tr.opis_innego_ladunku %}
<tr><td class="payment-label">&nbsp;&nbsp;Ładunek:</td><td class="payment-value">{% if tr.ladunek_inny == '1' %}{{ tr.opis_innego_ladunku | default('inny') }}{% else %}{{ tr.opis_ladunku | default('') }}{% endif %}</td></tr>
{% endif %}
{% if tr.data_rozp %}
<tr><td class="payment-label">&nbsp;&nbsp;Rozpoczęcie:</td><td class="payment-value">{{ tr.data_rozp }}</td></tr>
{% endif %}
{% if tr.data_zak %}
<tr><td class="payment-label">&nbsp;&nbsp;Zakończenie:</td><td class="payment-value">{{ tr.data_zak }}</td></tr>
{% endif %}
{% endfor %}
{% if wt.podmiot_posredniczacy == '1' %}
<tr><td class="payment-label">Podmiot pośredniczący:</td><td class="payment-value">Tak (art. 22 ust. 2d)</td></tr>
{% endif %}
</table>
{% endif %}

{# ===== ZAMOWIENIE (order for advance invoices) ===== #}
{% if zamowienie %}
<div class="section-header">Zamówienie</div>
{% if zamowienie.wartosc %}
<div class="small-text"><b>Wartość zamówienia: {{ zamowienie.wartosc | fmt_amt }}</b></div>
{% endif %}
{% if zamowienie.wiersze %}
<table class="items-table">
<thead>
<tr>
    <th>Lp.</th>
    <th>Nazwa</th>
    <th>J.m.</th>
    <th>Ilość</th>
    <th>Cena netto</th>
    <th>Wart. netto</th>
    <th>Stawka</th>
</tr>
</thead>
<tbody>
{% for w in zamowienie.wiersze %}
<tr>
    <td class="td-center">{{ w.nr | default('') }}</td>
    <td class="td-left">{{ w.p7z | default('') }}</td>
    <td class="td-center">{{ w.p8az | default('') }}</td>
    <td class="td-right">{{ w.p8bz | default('') | fmt_amt }}</td>
    <td class="td-right">{{ w.p9az | default('') | fmt_amt }}</td>
    <td class="td-right">{{ w.p11z | default('') | fmt_amt }}</td>
    <td class="td-center">{{ w.p12z | default('') | vat_label }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
{% endif %}

{# ===== ZALACZNIK (attachments) ===== #}
{% if zalacznik %}
<div class="section-header">Załączniki</div>
{% for blok in zalacznik %}
{% if blok.naglowek %}
<div class="sub-header">{{ blok.naglowek }}</div>
{% endif %}
{% for m in blok.metadane | default([]) %}
<div class="small-text">{{ m.klucz | default('') }}: {{ m.wartosc | default('') }}</div>
{% endfor %}
{% for a in blok.akapity | default([]) %}
<div class="small-text">{{ a }}</div>
{% endfor %}
{% endfor %}
{% endif %}

{# ===== FOOTER ===== #}
{% if footer_data.informacje %}
{% for info in footer_data.informacje %}
<div class="footer-info">{{ info }}</div>
{% endfor %}
{% endif %}

{% if footer_data.rejestry %}
{% for r in footer_data.rejestry %}
<div class="footer-registry">
    {% set parts = [] %}
    {% if r.nazwa %}{% set _ = parts.append(r.nazwa) %}{% endif %}
    {% if r.krs %}{% set _ = parts.append('KRS: ' + r.krs) %}{% endif %}
    {% if r.regon %}{% set _ = parts.append('REGON: ' + r.regon) %}{% endif %}
    {% if r.bdo %}{% set _ = parts.append('BDO: ' + r.bdo) %}{% endif %}
    {{ parts | join(' | ') }}
</div>
{% endfor %}
{% endif %}

{% if header.data_wytworzenia %}
<div class="footer-info">Data wytworzenia faktury: {{ header.data_wytworzenia }}</div>
{% endif %}


</body>
</html>
