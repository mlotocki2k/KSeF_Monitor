<?xml version="1.0" encoding="UTF-8"?>
<!--
  STUB — Faktura VAT RR Schema

  This is a reference stub. The authoritative XSD for FA_RR (Faktura VAT RR —
  rolnicza faktura ryczałtowa) is published by the Ministry of Finance at:

    https://www.podatki.gov.pl/ksef/dokumenty-do-pobrania/

  FA_RR uses namespace URI:
    urn:crd.gov.pl:KSeF:FA_RR:1:0

  FA_RR specific structure:
  - Podmiot1 — Nabywca/skupujący (the buyer, typically a company)
  - Podmiot2 — Rolnik ryczałtowy (the farmer/supplier)
  - FaRR — RR-specific block:
    - KwotaVatRR       — Amount of flat-rate VAT refund
    - StawkaVatRR      — Flat-rate VAT refund rate
    - P15_RR           — Total amount due (including VAT RR)
    - DataOdbioru      — Date of product delivery/receipt
    - Oswiadczenie     — Farmer's declaration text
  - Rolnik PESEL stored under Podmiot2/OsobaNaturalna/NrID

  The monitor_ksef parser (invoice_xml_parser.py) auto-detects FA_RR by namespace
  and routes to FA_RRInvoiceXMLParser with schema_type='FA_RR'.
  PDF uses invoice_pdf_fa_rr.html.j2 template.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="urn:crd.gov.pl:KSeF:FA_RR:1:0"
           xmlns="urn:crd.gov.pl:KSeF:FA_RR:1:0"
           elementFormDefault="qualified">
  <!-- Full schema available from Ministerstwo Finansów / CIRFMF -->
  <!-- See: https://github.com/CIRFMF/ksef-docs -->
</xs:schema>
